@model Ticket
@{
    ViewData["Title"] = $"Chamado #{Model.Number}";
}

<section class="ticket-detail">
    <div class="ticket-main">
        <div class="panel">
            <div class="d-flex justify-content-between gap-3">
                <div>
                    <div class="text-muted small">@Model.Project?.Name</div>
                    <h2>@Model.Type.GetDisplayName()</h2>
                </div>
                <span class="priority priority-@Model.Priority.ToString().ToLowerInvariant()">@Model.Priority.GetDisplayName()</span>
            </div>
            <p class="ticket-description">@Model.Description</p>
            <div class="detail-grid">
                <div><span>Status</span><strong>@Model.Status.GetDisplayName()</strong></div>
                <div><span>Abertura</span><strong>@Model.OpenedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</strong></div>
                <div><span>SLA</span><strong>@Model.SlaDueAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</strong></div>
                <div><span>Resolvido</span><strong>@(Model.ResolvedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</strong></div>
            </div>
        </div>

        <div class="panel">
            <div class="panel-title">Comentários</div>
            <div class="timeline">
                @foreach (var comment in Model.Comments)
                {
                    <div class="timeline-item">
                        <div class="small text-muted">@comment.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm") @(comment.IsInternal ? "Interno" : "Público")</div>
                        <p>@comment.Message</p>
                    </div>
                }
            </div>
            <form asp-action="AddComment" method="post" class="mt-3">
                <input type="hidden" name="ticketId" value="@Model.Id" />
                <textarea name="message" class="form-control" rows="3" placeholder="Adicionar comentário"></textarea>
                <div class="d-flex justify-content-between align-items-center mt-2">
                    <label class="form-check">
                        <input class="form-check-input" type="checkbox" name="isInternal" value="true" />
                        <span class="form-check-label">Comentário interno</span>
                    </label>
                    <button class="btn btn-primary" type="submit">Comentar</button>
                </div>
            </form>
        </div>
    </div>

    <aside class="ticket-side">
        <div class="panel">
            <div class="panel-title">Atualizar status</div>
            <form asp-action="ChangeStatus" method="post">
                <input type="hidden" name="ticketId" value="@Model.Id" />
                <select name="status" asp-items="Html.GetEnumSelectList<TicketStatus>()" class="form-select mb-2"></select>
                <button class="btn btn-outline-primary w-100" type="submit">Atualizar</button>
            </form>
        </div>

        <div class="panel">
            <div class="panel-title">Anexos</div>
            <form asp-action="Upload" method="post" enctype="multipart/form-data" class="mb-3">
                <input type="hidden" name="ticketId" value="@Model.Id" />
                <input type="file" name="file" class="form-control mb-2" />
                <button class="btn btn-outline-primary w-100" type="submit">Enviar arquivo</button>
            </form>
            <div class="attachment-list">
                @foreach (var attachment in Model.Attachments)
                {
                    <a href="@attachment.StoredFileName" target="_blank"><i class="bi bi-paperclip"></i> @attachment.OriginalFileName</a>
                }
            </div>
        </div>

        <div class="panel">
            <div class="panel-title">Histórico</div>
            @foreach (var log in Model.ChangeLogs)
            {
                <div class="small mb-2">@log.FieldName: @log.OldValue -> @log.NewValue</div>
            }
        </div>
    </aside>
</section>
