@model AssistanceRequest
@{
    ViewData["Title"] = "Editar assistência";
}

<form asp-action="Edit" method="post" class="form-panel">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="All" class="text-danger mb-3"></div>
    <div class="row g-3">
        <div class="col-md-6"><label asp-for="ClientName" class="form-label">Cliente</label><input asp-for="ClientName" class="form-control" /></div>
        <div class="col-md-6"><label asp-for="Contact" class="form-label">Contato</label><input asp-for="Contact" class="form-control" /></div>
        <div class="col-md-3"><label asp-for="VisitCompleted" class="form-label">Visita feita?</label><select asp-for="VisitCompleted" class="form-select"><option value="">Pendente</option><option value="true">Sim</option><option value="false">Não</option></select></div>
        <div class="col-md-3"><label asp-for="Completed" class="form-label">Concluído?</label><select asp-for="Completed" class="form-select"><option value="">Pendente</option><option value="true">Sim</option><option value="false">Não</option></select></div>
        <div class="col-md-3"><label asp-for="OrderPlaced" class="form-label">Pedido efetuado?</label><select asp-for="OrderPlaced" class="form-select"><option value="">Pendente</option><option value="true">Sim</option><option value="false">Não</option></select></div>
        <div class="col-md-3"><label asp-for="AssistanceDate" class="form-label">Data assistência</label><input asp-for="AssistanceDate" type="date" class="form-control" /></div>
        <div class="col-md-6"><label asp-for="Status" class="form-label">Status</label><select asp-for="Status" asp-items="ViewBag.Statuses" class="form-select"></select></div>
        <div class="col-12"><label asp-for="Notes" class="form-label">Observações</label><textarea asp-for="Notes" class="form-control" rows="4"></textarea></div>
    </div>
    <div class="form-actions"><a class="btn btn-outline-secondary" asp-action="Index">Cancelar</a><button class="btn btn-primary" type="submit">Salvar alterações</button></div>
</form>
