@model LoginViewModel
@{
    Layout = null;
}
<!doctype html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login - ArquiDesk</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
</head>
<body class="login-page">
    <main class="login-panel">
        <div class="brand mb-4"><span class="brand-mark">A</span><span>ArquiDesk</span></div>
        @if (TempData["Message"] != null)
        {
            <div class="alert alert-info">@TempData["Message"]</div>
        }
        <h1 class="auth-title">Entrar</h1>
        <p class="auth-subtitle">Acesse sua conta para acompanhar projetos, leads e chamados.</p>
        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
            <div class="mb-3">
                <label asp-for="Email" class="form-label">E-mail</label>
                <input asp-for="Email" class="form-control" autocomplete="email" />
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label">Senha</label>
                <input asp-for="Password" class="form-control" autocomplete="current-password" />
            </div>
            <label class="form-check mb-3">
                <input asp-for="RememberMe" class="form-check-input" />
                <span class="form-check-label">Manter conectado</span>
            </label>
            <button class="btn btn-primary w-100" type="submit">Entrar</button>
            <a class="d-block text-center mt-3" asp-action="ForgotPassword">Esqueci minha senha</a>
            <a class="d-block text-center mt-2" asp-action="Register" asp-route-returnUrl="@ViewData["ReturnUrl"]">Criar primeira conta</a>
        </form>
        <a class="d-block text-center mt-3" asp-controller="Home" asp-action="Index">Voltar para a apresentação</a>
    </main>
</body>
</html>
