<!doctype html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - ArquiDesk</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <aside class="sidebar">
            <a class="brand" asp-controller="Dashboard" asp-action="Index">
                <span class="brand-mark">A</span>
                <span>ArquiDesk</span>
            </a>
            <nav class="nav flex-column gap-1">
                <a class="nav-link" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2"></i> Dashboard</a>
                <a class="nav-link" asp-controller="Leads" asp-action="Index"><i class="bi bi-person-lines-fill"></i> Leads</a>
                <a class="nav-link" asp-controller="Negotiations" asp-action="Index"><i class="bi bi-cash-stack"></i> Negociações</a>
                <a class="nav-link" asp-controller="Tickets" asp-action="Index"><i class="bi bi-ticket-detailed"></i> Chamados</a>
                <a class="nav-link" asp-controller="Projects" asp-action="Index"><i class="bi bi-kanban"></i> Projetos</a>
                <a class="nav-link" asp-controller="Installations" asp-action="Index"><i class="bi bi-tools"></i> Montagens</a>
                <a class="nav-link" asp-controller="Assistance" asp-action="Index"><i class="bi bi-life-preserver"></i> Assistências</a>
                <a class="nav-link" asp-controller="Imports" asp-action="Index"><i class="bi bi-upload"></i> Importar</a>
                <a class="nav-link" asp-controller="Users" asp-action="Index"><i class="bi bi-people"></i> Usuários</a>
                <a class="nav-link" asp-controller="Reports" asp-action="Index"><i class="bi bi-file-earmark-spreadsheet"></i> Relatórios</a>
            </nav>
        </aside>
        <main class="main-content">
            <header class="topbar">
                <div>
                    <div class="text-muted small">Sistema de chamados para arquitetura e móveis planejados</div>
                    <h1>@(ViewData["Title"] ?? "ArquiDesk")</h1>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <a class="btn btn-primary" asp-controller="Tickets" asp-action="Create"><i class="bi bi-plus-lg"></i> Novo chamado</a>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a class="btn btn-outline-secondary" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right"></i></a>
                    }
                </div>
            </header>
            @RenderBody()
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
