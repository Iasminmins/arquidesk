@model Lead
@{
    ViewData["Title"] = "Editar lead";
}

<form asp-action="Edit" method="post" class="form-panel">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="All" class="text-danger mb-3"></div>
    <div class="row g-3">
        <div class="col-md-6"><label asp-for="Name" class="form-label">Nome</label><input asp-for="Name" class="form-control" /></div>
        <div class="col-md-6"><label asp-for="Contact" class="form-label">Contato</label><input asp-for="Contact" class="form-control" /></div>
        <div class="col-md-4"><label asp-for="Status" class="form-label">Status</label><select asp-for="Status" asp-items="ViewBag.Statuses" class="form-select"></select></div>
        <div class="col-md-4"><label asp-for="OwnerName" class="form-label">Responsável</label><input asp-for="OwnerName" class="form-control" /></div>
        <div class="col-md-4"><label asp-for="NextFollowUpAt" class="form-label">Próximo contato</label><input asp-for="NextFollowUpAt" type="date" class="form-control" /></div>
        <div class="col-md-4"><label asp-for="Answered" class="form-label">Atendeu?</label><select asp-for="Answered" class="form-select"><option value="">Pendente</option><option value="true">Sim</option><option value="false">Não</option></select></div>
        <div class="col-md-4"><label asp-for="Interested" class="form-label">Tem interesse?</label><select asp-for="Interested" class="form-select"><option value="">Pendente</option><option value="true">Sim</option><option value="false">Não</option></select></div>
        <div class="col-md-4"><label asp-for="ProjectSent" class="form-label">Mandou projeto?</label><select asp-for="ProjectSent" class="form-select"><option value="">Pendente</option><option value="true">Sim</option><option value="false">Não</option></select></div>
        <div class="col-12"><label asp-for="Observations" class="form-label">Observações</label><textarea asp-for="Observations" class="form-control" rows="4"></textarea></div>
    </div>
    <div class="form-actions"><a class="btn btn-outline-secondary" asp-action="Index">Cancelar</a><button class="btn btn-primary" type="submit">Salvar alterações</button></div>
</form>
